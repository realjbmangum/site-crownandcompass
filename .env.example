# Crown and Compass — Environment Variables
# Copy to .env for local dev. Never commit .env.

# SendGrid — used by the Join / Contact form to notify Brian of a new inquiry.
# NOTIFICATION_EMAIL must be a verified sender (or on an authenticated domain)
# in SendGrid; it is used as both the "to" and the "from" address.
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFICATION_EMAIL=brian@example.com

# D1 is configured via wrangler.toml binding (no env var needed locally).
# For Cloudflare Pages: add the D1 binding "DB" in Pages → Settings → Bindings.

# NOTE: The newsletter engine (ADMIN_SECRET / SITE_URL / MAILING_ADDRESS) was
# removed. It will be rebuilt inside the member-app admin, behind real auth,
# with the finished newsletter design. Do not set those vars until then.
