# Crown and Compass — Environment Variables
# Copy to .env for local dev. Never commit .env.

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFICATION_EMAIL=brian@example.com

# Admin — used to protect /api/newsletter/send
# Set a long random string (e.g. openssl rand -hex 32)
ADMIN_SECRET=your_admin_secret_here

# Public site URL — used in newsletter email + unsubscribe links.
# Set this in Cloudflare Pages once the final domain is attached.
SITE_URL=https://crownandcompass.com

# Physical mailing address shown in the newsletter footer (required by CAN-SPAM
# before any broadcast). A PO box or registered-agent address is fine.
MAILING_ADDRESS=

# D1 is configured via wrangler.toml binding (no env var needed locally)
# For Cloudflare Pages: add D1 binding in Pages dashboard → Settings → Bindings
