---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <svg class="footer-logo" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.4" />
        <polygon points="20,4 22.4,17.6 20,20 17.6,17.6" fill="currentColor" />
        <polygon points="20,36 17.6,22.4 20,20 22.4,22.4" fill="currentColor" opacity="0.5" />
        <polygon points="36,20 22.4,17.6 20,20 22.4,22.4" fill="currentColor" opacity="0.5" />
        <polygon points="4,20 17.6,22.4 20,20 17.6,17.6" fill="currentColor" opacity="0.5" />
      </svg>
      <p class="footer-name">Crown &amp; Compass</p>
      <p class="footer-tagline">The Walk. Long. Slow. Together.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/compass">The Compass</a>
      <a href="/books">Books</a>
      <a href="/about">About</a>
      <a href="/join">Join</a>
    </nav>

    <p class="footer-copy">
      &copy; {year} Crown and Compass. Free because the Gospel is free.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--bg-base);
    border-top: 1px solid var(--border-soft);
    padding: 3rem 1.75rem;
    margin-top: auto;
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    max-width: 70rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-logo {
    width: 34px;
    height: 34px;
    color: var(--accent);
  }

  .footer-name {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .footer-tagline {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 0.9375rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0;
  }

  .footer-nav { display: flex; gap: 1.75rem; flex-wrap: wrap; justify-content: center; }

  .footer-nav a {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.15s ease;
  }

  .footer-nav a:hover { color: var(--text-primary); }

  .footer-copy {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: var(--text-faint);
    margin: 0;
  }
</style>
