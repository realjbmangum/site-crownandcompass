---
interface Props {
  name: string;
  hook: string;
  href: string;
}

const { name, hook, href } = Astro.props;
---

<a href={href} class="pillar-card">
  <span class="pillar-name">{name}</span>
  <span class="pillar-hook">{hook}</span>
  <span class="pillar-more" aria-hidden="true">Read <span class="arrow">&rsaquo;</span></span>
</a>

<style>
  .pillar-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 1.375rem 1.625rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    border-radius: 0 0 6px 6px;
    transition: transform 0.25s ease, background-color 0.25s ease;
    text-decoration: none;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    background-color: var(--bg-card-hi);
  }

  .pillar-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .pillar-hook {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.125rem;
    color: var(--text-primary);
    line-height: 1.5;
    flex: 1;
  }

  .pillar-more {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .pillar-more .arrow { transition: transform 0.2s ease; display: inline-block; }
  .pillar-card:hover .pillar-more { color: var(--accent); }
  .pillar-card:hover .arrow { transform: translateX(3px); }
</style>
