---
import BaseLayout from '../layouts/BaseLayout.astro';
import books from '../data/books.json';

const currentBook = books.find(b => b.currentRead);
const pastReads = books.filter(b => !b.currentRead);

const pillarLabels: Record<string, string> = {
  body: 'Body',
  being: 'Being',
  balance: 'Balance',
  business: 'Business',
};
---

<BaseLayout
  title="The Reading List | Crown and Compass"
  description="The books Crown and Compass reads together. Field guides from past chapters, the current read, and a broader list for men who want to keep walking."
>

  <!-- ============================ HERO ============================ -->
  <section class="books-hero">
    <div class="books-hero-bg" aria-hidden="true"></div>
    <div class="section-container">
      <div class="books-hero-inner reveal">
        <p class="kicker">Books</p>
        <h1 class="books-headline">The Reading List</h1>
        <p class="books-subtext">
          Every Chapter reads the same book at the same time. The book is the common ground
          that makes honest conversation possible. Below is what we're reading now, what
          we've worked through, and what we recommend for the walk.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================= NOW READING ======================== -->
  <section class="section-pad band-raise firelight now-reading">
    <div class="section-container">
      <p class="kicker kicker-rule reveal">{currentBook ? 'Now Reading' : 'Between Books'}</p>

      {currentBook ? (
        <div class="now-card reveal">
          <div class="now-cover-wrap">
            <img
              src={currentBook.cover}
              alt={currentBook.title}
              class="now-cover"
              loading="eager"
            />
          </div>
          <div class="now-body">
            <p class="now-label">Current Chapter Book</p>
            <h2 class="now-title">{currentBook.title}</h2>
            <p class="now-author">{currentBook.author}</p>
            <p class="now-desc">{currentBook.description}</p>
            <div class="now-pillars">
              {currentBook.pillars.map(p => (
                <span class="pillar-tag">{pillarLabels[p]}</span>
              ))}
            </div>
            <div class="now-actions">
              <a href={currentBook.amazonUrl} target="_blank" rel="noopener noreferrer" class="btn-amber">
                Get the book
              </a>
              {currentBook.fieldGuideUrl && (
                <a href={currentBook.fieldGuideUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">
                  Download Field Guide
                </a>
              )}
            </div>
          </div>
        </div>
      ) : (
        <div class="between-card reveal">
          <h2 class="between-title">We're between books right now.</h2>
          <p class="between-text">
            The chapter is choosing what we read next. Until then, the full reading list is
            below. Pick one up and start walking.
          </p>
          <a href="#reading-list" class="btn-ghost">Browse the reading list</a>
        </div>
      )}
    </div>
  </section>

  <!-- ======================= THE READING LIST ===================== -->
  {pastReads.length > 0 && (
    <section id="reading-list" class="section-pad">
      <div class="section-container">
        <div class="section-head reveal">
          <p class="kicker kicker-rule">The Reading List</p>
          <h2>Books We've Read Together</h2>
          <p class="section-sub">
            Every book the chapter has worked through. Field Guides — discussion questions,
            chapter summaries, and prompts for The Round — will be added as they're completed.
          </p>
        </div>
        <div class="book-grid">
          {pastReads.map(book => (
            <article class="card book-card reveal">
              <div class="book-cover-wrap">
                <img
                  src={book.cover}
                  alt={book.title}
                  class="book-cover"
                  loading="lazy"
                  width="92"
                />
              </div>
              <div class="book-info">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author}</p>
                <div class="book-pillars">
                  {book.pillars.map(p => (
                    <span class="pillar-tag pillar-tag-sm">{pillarLabels[p]}</span>
                  ))}
                </div>
                <p class="book-desc">{book.description}</p>
                <div class="book-actions">
                  <a href={book.amazonUrl} target="_blank" rel="noopener noreferrer" class="btn-amber btn-sm">
                    Buy →
                  </a>
                  {book.fieldGuideUrl ? (
                    <a href={book.fieldGuideUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost btn-sm">
                      Field Guide →
                    </a>
                  ) : (
                    <span class="guide-pending">Field Guide coming</span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========================= SUGGEST CTA ======================== -->
  <section class="section-pad band-raise suggest">
    <div class="section-container">
      <div class="suggest-inner reveal">
        <p class="kicker suggest-kicker">Suggest a Book</p>
        <p class="suggest-text">
          Reading something that should be on this list? Reach out to Brian directly.
        </p>
        <a href="https://x.com/realjbmangum" target="_blank" rel="noopener noreferrer" class="btn-ghost">
          @realjbmangum on X
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .books-hero {
    position: relative;
    overflow: hidden;
    padding: 5.5rem 0 4.5rem;
  }
  .books-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(100% 80% at 50% -25%, rgba(201, 133, 58, 0.15), transparent 55%),
      linear-gradient(180deg, #0a0b10 0%, var(--bg-base) 72%);
  }
  .books-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }
  .books-hero .kicker { margin-bottom: 1.25rem; }
  .books-headline {
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    line-height: 1.08;
    margin: 0 0 1.25rem;
  }
  .books-subtext {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: clamp(1rem, 2vw, 1.1875rem);
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0 auto;
    max-width: 40rem;
  }

  /* ---------- Section head (matches home) ---------- */
  .section-head { max-width: 42rem; margin-bottom: 2.75rem; }
  .section-head .kicker { margin-bottom: 1rem; }
  .section-sub {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 1rem 0 0;
  }

  /* ---------- Compact buttons for grid cards ---------- */
  .btn-sm {
    padding: 0.5rem 1.05rem;
    font-size: 0.8125rem;
  }

  /* ---------- Pillar tags ---------- */
  .pillar-tag {
    display: inline-block;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(201, 133, 58, 0.35);
    padding: 0.22rem 0.55rem;
    border-radius: 2px;
    line-height: 1;
  }
  .pillar-tag-sm { font-size: 0.625rem; padding: 0.2rem 0.45rem; }

  /* ---------- Now Reading ---------- */
  .now-reading .kicker { margin-bottom: 1.875rem; }

  .now-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.75rem;
    align-items: start;
    background-color: var(--bg-card);
    border: 1px solid rgba(201, 133, 58, 0.45);
    border-radius: 8px;
    padding: 2.25rem;
  }
  @media (max-width: 640px) {
    .now-card { grid-template-columns: 1fr; gap: 1.75rem; padding: 1.75rem; }
  }

  .now-cover {
    width: 152px;
    height: auto;
    max-width: 100%;
    display: block;
    border: 1px solid var(--border);
    border-radius: 3px;
    box-shadow: 0 10px 34px rgba(0, 0, 0, 0.55);
  }
  @media (max-width: 640px) {
    .now-cover { width: 116px; }
  }

  .now-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.625rem;
  }
  .now-title {
    font-size: clamp(1.625rem, 3vw, 2.25rem);
    margin: 0 0 0.35rem;
    line-height: 1.15;
  }
  .now-author {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 1.0625rem;
    color: var(--text-muted);
    margin: 0 0 1.25rem;
  }
  .now-desc {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0 0 1.375rem;
  }
  .now-pillars {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.625rem;
  }
  .now-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }

  /* ---------- Between-books state ---------- */
  .between-card {
    max-width: 40rem;
    margin: 0 auto;
    text-align: center;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 3rem 2rem;
  }
  .between-title { margin: 0 0 1rem; }
  .between-text {
    font-family: 'DM Sans', system-ui, sans-serif;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 34rem;
    margin: 0 auto 1.875rem;
  }

  /* ---------- Reading List grid ---------- */
  .book-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 720px) {
    .book-grid { grid-template-columns: 1fr; }
  }

  .book-card {
    display: flex;
    gap: 1.375rem;
    align-items: flex-start;
  }
  @media (max-width: 420px) {
    .book-card { flex-direction: column; }
  }

  .book-cover-wrap { flex-shrink: 0; }
  .book-cover {
    width: 92px;
    height: auto;
    max-width: 100%;
    display: block;
    border: 1px solid var(--border);
    border-radius: 3px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.45);
  }

  .book-info { flex: 1; min-width: 0; }
  .book-title {
    font-size: 1.3125rem;
    margin: 0 0 0.15rem;
    line-height: 1.25;
  }
  .book-author {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
  }
  .book-pillars {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.875rem;
  }
  .book-desc {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }
  .book-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .guide-pending {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--text-faint);
  }

  /* ---------- Suggest CTA ---------- */
  .suggest-inner {
    text-align: center;
    max-width: 34rem;
    margin: 0 auto;
  }
  .suggest-kicker {
    display: block;
    margin-bottom: 1rem;
  }
  .suggest-text {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 1.75rem;
  }
</style>
